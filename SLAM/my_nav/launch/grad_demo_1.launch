<launch>
  <!-- =================================================================== -->
  <!-- ===== 공통 인자 ===== -->
  <!-- =================================================================== -->
  <arg name="record" default="false"/>
  <arg name="waypoints_yaml" default="$(find my_nav)/config/waypoints.yaml"/>

  <!-- 카메라 인자 -->
  <arg name="cam_device" default="/dev/video2"/>
  <arg name="cam_info_url" default="file:///home/limhs/catkin_ws/src/aruco_detector/config/camera.yaml"/>

  <!-- 아루코/도킹 컨트롤러 사용 여부 -->
  <arg name="enable_camera_pipeline" default="true"/>
  <arg name="enable_marker_controller" default="true"/>

  <!-- =================================================================== -->
  <!-- ===== 1) 라이다 필터 ===== -->
  <!-- =================================================================== -->
  <node pkg="laser_filters" type="scan_to_scan_filter_chain" name="scan_filter" output="screen">
    <rosparam command="load" file="$(find my_nav)/config/laser_filter.yaml" />
    <remap from="scan" to="/scan" />
    <remap from="scan_filtered" to="/scan_filtered" />
  </node>

  <!-- =================================================================== -->
  <!-- ===== 2) TF 고정(라이다 / IMU / 카메라) ===== -->
  <!-- =================================================================== -->
  <node pkg="tf"
      type="static_transform_publisher"
      name="base_to_amr_base_tf"
      args="0 0 0 0 0 0 base_link amr_base_link 100"/>
      
  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_link_to_laser"
        args="0 0 0.32 0 0 3.141592 base_link laser_frame" />

  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_link_to_imu"
        args="0 0 0.27 0 0 0 base_link imu_link" />

  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_link_to_usb_cam"
        args="0.10 0.0 0.27 0 0 0 base_link usb_cam" />

  <!-- =================================================================== -->
  <!-- ===== 3) nav stack 관리자 ===== -->
  <!-- ===== map_server / amcl / move_base 는 nav_stack.launch 에서 실행 ===== -->
  <!-- =================================================================== -->
  <node pkg="my_robot_odom" type="map_mux.py" name="map_mux" output="screen">
    <!-- 어떤 맵으로 시작할지 -->
    <param name="start_with_map_b" value="false"/>
    <param name="publish_init_on_start" value="true"/>

    <!-- nav_stack.launch 실행 정보 -->
    <param name="nav_launch_pkg" value="my_nav"/>
    <param name="nav_launch_file" value="nav_stack.launch"/>
    <param name="nav_record" value="false"/>

    <!-- 맵 파일 -->
    <param name="map_a_file" value="/home/limhs/catkin_ws/src/my_map/map_1F.yaml"/>
    <param name="map_b_file" value="/home/limhs/catkin_ws/src/my_map/map_vcc.yaml"/>

    <!-- 초기 pose -->
    <rosparam param="mapA_initial">[0, 0, 0]</rosparam>
    <rosparam param="mapB_initial">[4.72, -16.67, -3.14]</rosparam>

    <!-- covariance -->
    <param name="pose_cov_xy" value="0.25"/>
    <param name="pose_cov_yaw" value="0.20"/>

    <param name="initialpose_topic" value="/initialpose"/>
    <param name="amcl_pose_topic" value="/amcl_pose"/>
    <param name="move_base_action_name" value="move_base"/>

    <!-- clear costmap -->
    <param name="clear_costmap" value="true"/>
    <param name="clear_srv_name" value="/move_base/clear_costmaps"/>
    <param name="post_clear_delay" value="1.0"/>
    <param name="double_clear" value="true"/>

    <!-- 재기동 타이밍 -->
    <param name="switch_settle_sec" value="2.0"/>
    <param name="startup_timeout" value="20.0"/>
    <param name="amcl_wait_timeout" value="10.0"/>
    <param name="shutdown_timeout" value="8.0"/>
  </node>

  <!-- =================================================================== -->
  <!-- ===== 4) odom / imu ===== -->
  <!-- =================================================================== -->
  <node pkg="my_robot_odom" type="odom_imu_grad_demo.py" name="odom_imu" output="screen" respawn="true">
    <param name="max_cmd_vel_x" value="0.22"/>
    <param name="max_cmd_vel_theta" value="0.8"/>
    <param name="pwm_slew_step" value="4"/>
    <param name="gamepad_override_timeout" value="0.3"/>
    <param name="turn_deadband" value="0.2"/>

    <param name="topic_cmd_nav" value="/cmd_vel_nav"/>
    <param name="topic_cmd_doc" value="/cmd_vel_doc"/>
    <param name="topic_doc_pwm" value="/doc_pwm_cmd"/>

    <param name="max_doc_vel_x" value="0.08"/>
    <param name="max_doc_vel_theta" value="0.35"/>

    <param name="doc_pwm_min" value="0"/>
    <param name="doc_pwm_max" value="20"/>
    <param name="doc_pwm_deadband" value="4"/>
    <param name="doc_pwm_slew_step" value="4"/>

    <param name="doc_thresh_lin" value="0.01"/>
    <param name="doc_thresh_ang" value="0.05"/>
    <param name="doc_turn_deadband" value="0.10"/>
    <param name="doc_ang_ema_alpha" value="0.4"/>

    <param name="topic_doc_char" value="/doc_cmd_char"/>

    <param name="mode_initial" value="1"/>
    <param name="allow_keyboard_override" value="true"/>
  </node>
  

  <!-- =================================================================== -->
  <!-- ===== 5) EKF ===== -->
  <!-- =================================================================== -->
  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se_odom" output="screen" respawn="true">
    <rosparam command="load" file="$(find my_nav)/config/ekf.yaml" />
  </node>

  <!-- =================================================================== -->
  <!-- ===== 6) 카메라 파이프라인 ===== -->
  <!-- =================================================================== -->
  <group if="$(arg enable_camera_pipeline)">
    <!-- USB 카메라 -->
    <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
      <param name="video_device" value="$(arg cam_device)"/>
      <param name="pixel_format" value="mjpeg"/>
      <param name="image_width"  value="1280"/>
      <param name="image_height" value="720"/>
      <param name="framerate"    value="40"/>
      <param name="camera_name" value="usb_cam"/>
      <param name="camera_frame_id" value="usb_cam"/>
      <param name="camera_info_url" value="$(arg cam_info_url)"/>
    </node>

    <!-- image_proc -->
    <group ns="usb_cam">
      <node pkg="image_proc" type="image_proc" name="image_proc"/>
    </group>

    <!-- 아루코 디텍터 -->
    <node name="aruco_detector" pkg="aruco_detector" type="aruco_detector_node" output="screen">
      <remap from="~image"       to="/usb_cam/image_raw"/>
      <remap from="~camera_info" to="/usb_cam/camera_info"/>
      <param name="use_optical_to_base" value="true"/>
    </node>
  </group>

  <!-- =================================================================== -->
  <!-- ===== 7) 마커 기반 접근 컨트롤러 ===== -->
  <!-- =================================================================== -->
  <group if="$(arg enable_marker_controller)">
    <node pkg="aruco_detector" type="marker_pose_controller_grad_demo.py"
      name="marker_pose_controller" output="screen">

      <!-- 출력 토픽 -->
      <param name="cmd_doc_topic"  value="/cmd_vel_doc"/>
      <param name="char_cmd_topic" value="/doc_cmd_char"/>
      <param name="doc_pwm_topic"  value="/doc_pwm_cmd"/>

      <!-- 입력 토픽 -->
      <param name="topic_pose_z"    value="/aruco/pose_z"/>
      <param name="topic_pose_x"    value="/aruco/pose_x"/>
      <param name="topic_marker_id" value="/aruco/marker_id"/>
      <param name="topic_mission"   value="/camera_mission_marker"/>
      <param name="topic_yaw"       value="/aruco/yaw_b_m"/>

      <!-- 완료 토픽: waypoint_navigator와 맞추기 위해 중요 -->
      <param name="topic_done" value="/camera_mission_done"/>
      <param name="docking_done_topic" value="/marker_docking_done"/>

    </node>
  </group>

  <!-- =================================================================== -->
  <!-- ===== 8) 일반 주행 모드 (record=false) ===== -->
  <!-- =================================================================== -->
  <group unless="$(arg record)">
    <include file="$(find amr_re_description)/launch/display.launch"/>

    <node pkg="my_robot_odom" type="waypoint_navigator_grad_demo.py" name="waypoint_navigator" output="screen"
          launch-prefix="bash -c 'sleep 4; $0 $@'">
      <param name="yaml_path" value="$(arg waypoints_yaml)"/>
      <param name="enable_uart" value="false"/>
      <param name="goal_timeout" value="120.0"/>
      <param name="retry_max" value="2"/>
      
      <param name="marker_mission_topic" value="/camera_mission_marker"/>
      <param name="panel_mission_topic" value="/camera_mission_panel"/>

      <param name="map_frame" value="map"/>
      <param name="switch_map_srv" value="/map_mux/switch_map"/>
      <param name="switch_settle_sec" value="2.0"/>

      <param name="wait_for_amcl" value="false"/>
      <param name="move_base_wait_timeout" value="20.0"/>
      <param name="amcl_wait_timeout_after_switch" value="12.0"/>
      <param name="amcl_pose_topic" value="/amcl_pose"/>
      <param name="move_base_action_name" value="move_base"/>
      <param name="use_legacy_camera_mission_done" value="true"/>
      <param name="legacy_camera_mission_done_topic" value="/camera_mission_done"/>
    </node>
  </group>

  <!-- =================================================================== -->
  <!-- ===== 9) 기록 모드 (record=true) ===== -->
  <!-- =================================================================== -->
  <group if="$(arg record)">
    <include file="$(find amr_re_description)/launch/display.launch"/>

    <node pkg="my_robot_odom" type="waypoint_recorder.py" name="waypoint_recorder" output="screen">
      <param name="map_frame" value="map"/>
      <param name="output" value="$(arg waypoints_yaml)"/>
      <param name="name_prefix" value="p"/>
    </node>
  </group>
</launch>
