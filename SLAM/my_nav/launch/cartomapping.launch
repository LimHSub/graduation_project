<launch>
  <!-- 1) YDLIDAR 드라이버 -->
  <node name="ydlidar_lidar_publisher" pkg="ydlidar_ros_driver" type="ydlidar_ros_driver_node" output="screen" respawn="false">
    <!-- string property -->
    <param name="port" type="string" value="/dev/ttyUSB0"/>  
    <param name="frame_id" type="string" value="laser_frame"/>
    <param name="ignore_array" type="string" value=""/>

    <!-- int property -->
    <param name="baudrate" type="int" value="230400"/>  
    <param name="lidar_type" type="int" value="1"/>  
    <param name="device_type" type="int" value="0"/>  
    <param name="sample_rate" type="int" value="9"/>  
    <param name="abnormal_check_count" type="int" value="4"/>  

    <!-- bool property -->	
    <param name="resolution_fixed" type="bool" value="true"/>
    <param name="auto_reconnect"   type="bool" value="true"/>
    <param name="reversion"        type="bool" value="true"/>
    <param name="inverted"         type="bool" value="true"/>
    <param name="isSingleChannel"  type="bool" value="false"/>
    <param name="intensity"        type="bool" value="false"/>
    <param name="support_motor_dtr" type="bool" value="false"/>
    <param name="invalid_range_is_inf" type="bool" value="false"/>
    <param name="point_cloud_preservative" type="bool" value="false"/>

    <!-- float property -->
    <param name="angle_min" type="double" value="-180" />
    <param name="angle_max" type="double" value="180" />
    <param name="range_min" type="double" value="0.13" />
    <param name="range_max" type="double" value="16.0" />
    <param name="frequency" type="double" value="10.0"/>
  </node>

  <!-- 2) Scan Filter (scan → scan_filtered) -->
  <node pkg="laser_filters" type="scan_to_scan_filter_chain" name="scan_filter" output="screen">
    <rosparam command="load" file="$(find my_nav)/config/laser_filter.yaml" />
    <remap from="scan" to="/scan" />
    <remap from="scan_filtered" to="/scan_filtered" />
  </node>

  <!-- 3) Odom + IMU 퍼블리셔 (엔코더+IMU 융합 코드 실행) -->
  <node pkg="my_robot_odom" type="odom_uart_publisher.py" name="odom_imu" output="screen"/>

  <!-- 4) TF: base_link → laser_frame -->
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_laser"
        args="0 0 0.33 0 0 0 base_link laser_frame 40" />

  <!-- 5) TF: base_link → imu_link -->
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_imu"
        args="0 0 0.27 0 0 0 base_link imu_link 40"/>
</launch>

