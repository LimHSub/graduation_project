<launch>
  <!-- ===== 공통 인자 ===== -->
  <arg name="record" default="false"/>
  <arg name="waypoints_yaml" default="$(find my_nav)/config/waypoints.yaml"/>
  <!-- 카메라 인자 -->
  <arg name="cam_device" default="/dev/video2"/>
  <arg name="cam_info_url" default="file:///home/limhs/catkin_ws/src/aruco_detector/config/camera.yaml"/>

  <!-- ===== 1) 라이다 필터 ===== -->
  <node pkg="laser_filters" type="scan_to_scan_filter_chain" name="scan_filter" output="screen">
    <rosparam command="load" file="$(find my_nav)/config/laser_filter.yaml" />
    <remap from="scan" to="/scan" />
    <remap from="scan_filtered" to="/scan_filtered" />
  </node>

  <!-- =================================================================== -->
  <!-- ===== 2) TF 고정(라이다/IMU/카메라) ===== -->
  <!-- =================================================================== -->
  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_link_to_laser"
        args="0 0 0.32 0 0 3.141592 base_link laser_frame" />

  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_link_to_imu"
        args="0 0 0.27 0 0 0 base_link imu_link" />

  <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_link_to_usb_cam"
        args="0.10 0.0 0.27 0 0 0 base_link usb_cam" />

  <!-- =================================================================== -->
  <!-- ===== 3) map_server 2개: ✅ 네임스페이스로 감싸서 /static_map 충돌 제거 ===== -->
  <!-- =================================================================== -->

  <!-- Map A -->
  <group ns="mapA">
    <node pkg="map_server" type="map_server" name="map_server"
          args="/home/limhs/catkin_ws/src/my_map/map_vcc.yaml" output="screen">
      <!-- 토픽은 그대로 /map_A 로 내보내되, 서비스는 /mapA/static_map 으로 분리됨 -->
      <remap from="map" to="/map_A"/>
      <remap from="map_metadata" to="/map_A_metadata"/>
    </node>
  </group>

  <!-- Map B -->
  <group ns="mapB">
    <node pkg="map_server" type="map_server" name="map_server"
          args="/home/limhs/catkin_ws/src/my_map/map_test.yaml" output="screen">
      <remap from="map" to="/map_B"/>
      <remap from="map_metadata" to="/map_B_metadata"/>
    </node>
  </group>

  <!-- =================================================================== -->
  <!-- ===== 3.5) map_mux: ✅ /map + /map_metadata + /static_map 을 단일화 ===== -->
  <!-- =================================================================== -->
  <node pkg="my_robot_odom" type="map_mux.py" name="map_mux" output="screen">
    <param name="topic_map_a" value="/map_A"/>
    <param name="topic_map_b" value="/map_B"/>

    <param name="topic_meta_a" value="/map_A_metadata"/>
    <param name="topic_meta_b" value="/map_B_metadata"/>

    <!-- 시작은 A -->
    <param name="start_with_map_b" value="false"/>

    <!-- 부팅 시 initpose 자동발행은 OFF -->
    <param name="publish_init_on_start" value="false"/>

    <!-- 전환 시 costmap clear는 ON -->
    <param name="clear_costmap" value="true"/>
    <param name="clear_srv_name" value="/move_base/clear_costmaps"/>
    <param name="post_clear_delay" value="0.3"/>

    <param name="switch_settle_sec" value="0.6"/>
    <param name="wait_for_map_odom_tf" value="true"/>
    <param name="tf_wait_timeout" value="1.5"/>

    <param name="nudge_enable" value="true"/>
    <param name="nudge_cmd_topic" value="/cmd_vel_nav"/>
    <param name="nudge_ang_z" value="0.35"/>
    <param name="nudge_duration" value="0.25"/>

    <!-- 초기 pose -->
    <rosparam param="mapA_initial">[0, 0, 0]</rosparam>
    <rosparam param="mapB_initial">[2.0536, -6.0878, -1.5095]</rosparam>

    <!-- covariance -->
    <param name="pose_cov_xy" value="0.25"/>
    <param name="pose_cov_yaw" value="0.20"/>

    <param name="initialpose_topic" value="/initialpose"/>
  </node>

  <!-- ===== 4) 오도메트리/IMU/EKF ===== -->
  <node pkg="my_robot_odom" type="odom_imu.py" name="odom_imu" output="screen">
    <param name="max_cmd_vel_x" value="0.3"/>
    <param name="max_cmd_vel_theta" value="0.3"/>
    <param name="pwm_slew_step" value="6"/>
    <param name="gamepad_override_timeout" value="1.0"/>
    <param name="turn_deadband" value="0.16"/>
    <param name="topic_cmd_nav" value="/cmd_vel_nav"/>
    <param name="topic_cmd_doc" value="/cmd_vel_doc"/>
    <param name="mode_initial" value="1"/>
    <param name="allow_keyboard_override" value="true"/>
  </node>

  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se_odom" output="screen" respawn="true">
    <rosparam command="load" file="$(find my_nav)/config/ekf.yaml" />
  </node>

  <!-- ===== 5) AMCL ===== -->
  <node pkg="amcl_custom" type="amcl_custom" name="amcl" output="screen">
    <param name="odom_frame_id" value="odom" />
    <param name="base_frame_id" value="base_link" />
    <param name="scan_topic" value="/scan_filtered" />
    <param name="min_particles" value="2000" />
    <param name="max_particles" value="6000" />
    <param name="laser_max_beams" value="60" />
    <param name="laser_max_range" value="16.0" />
    <param name="laser_min_range" value="0.1" />
    <param name="odom_alpha1" value="0.01" />
    <param name="odom_alpha2" value="0.01" />
    <param name="odom_alpha3" value="0.3" />
    <param name="odom_alpha4" value="0.5" />
    <param name="laser_z_hit" value="0.7" />
    <param name="laser_sigma_hit" value="0.2" />
    <param name="laser_z_rand" value="0.05" />
    <param name="transform_tolerance" value="1.0" />
    <param name="update_min_d" value="0.05" />
    <param name="update_min_a" value="0.05" />
    <param name="resample_interval" value="2" />
    <param name="recovery_alpha_slow" value="0.001" />
    <param name="recovery_alpha_fast" value="0.1" />
  </node>

  <!-- ===== 6) move_base ===== -->
  <group unless="$(arg record)">
    <include file="$(find museum_robot_description)/launch/display.launch"/>

    <node pkg="move_base" type="move_base" name="move_base" output="screen">
      <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
      <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>

      <rosparam file="$(find my_nav)/config/costmap.yaml" command="load" ns="" />
      <rosparam file="$(find my_nav)/config/move_base.yaml" command="load" />
      <rosparam file="$(find my_nav)/config/prohibition_layer.yaml" command="load" ns="global_costmap"/>
      <rosparam file="$(find my_nav)/config/prohibition_layer.yaml" command="load" ns="local_costmap"/>

      <param name="planner_frequency" value="2.0" />
      <param name="controller_frequency" value="10.0" />

      <param name="global_costmap/transform_tolerance" value="1.0" />
      <param name="local_costmap/transform_tolerance" value="1.0" />

      <!-- 멀티맵: map 업데이트 계속 반영 -->
      <param name="global_costmap/static_layer/first_map_only" value="false" />

      <remap from="/cmd_vel" to="/cmd_vel_nav"/>
    </node>

    <node pkg="my_robot_odom" type="waypoint_navigator_multi.py" name="waypoint_navigator" output="screen">
      <param name="yaml_path" value="$(arg waypoints_yaml)"/>
      <param name="goal_timeout" value="120.0"/>
      <param name="retry_max" value="2"/>

      <param name="map_frame" value="map"/>
      <param name="switch_map_srv" value="/map_mux/switch_map"/>
      <param name="switch_settle_sec" value="0.5"/>

      <param name="wait_for_amcl" value="false"/>
    </node>
  </group>

  <!-- ===== 7) 기록 모드 ===== -->
  <group if="$(arg record)">
    <include file="$(find vcc_URDF_description)/launch/display.launch"/>

    <node pkg="my_robot_odom" type="waypoint_recorder.py" name="waypoint_recorder" output="screen">
      <param name="map_frame" value="map"/>
      <param name="output" value="$(arg waypoints_yaml)"/>
      <param name="name_prefix" value="p"/>
    </node>

    <node pkg="move_base" type="move_base" name="move_base" output="screen">
      <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
      <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS"/>
      <rosparam file="$(find my_nav)/config/costmap.yaml" command="load" ns="" />
      <rosparam file="$(find my_nav)/config/move_base.yaml" command="load" />
      <param name="controller_frequency" value="5.0" />
      <param name="global_costmap/transform_tolerance" value="1.0" />
      <param name="local_costmap/transform_tolerance" value="1.0" />
      <param name="global_costmap/static_layer/first_map_only" value="false" />

      <remap from="/move_base_simple/goal" to="/move_base_simple/goal_live"/>
      <remap from="/cmd_vel" to="/cmd_vel_nav"/>
    </node>
  </group>

</launch>
